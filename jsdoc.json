{
  "tags": {
    "allowUnknownTags": true
  },
  "source": {
    "include": ["README.md", "dist"],
    "includePattern": ".+\\.(js|md)$",
    "excludePattern": "(^|\\/)_(.*)"
  },
  "plugins": ["plugins/markdown"],
  "opts": {
    "destination": "docs",
    "recurse": true,
    "template": "node_modules/jsdoc/templates/default",
    "encoding": "utf8"
  },
  "templates": {
    "default": {
      "includeDate": false
    }
  }
}
